# Required
PORT=3001
FRONTEND_URL=https://your-frontend.vercel.app,https://your-preview-frontend.vercel.app
SHARE_BASE_URL=https://your-frontend.vercel.app
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/swiftshare
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=swiftshare

# Optional integrations
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
GEMINI_API_KEY=
SENTRY_DSN=

# Optional tuning
MAX_FILE_SIZE_MB=100
MAX_FILE_COUNT=5
SESSION_EXPIRY_MINUTES=10
MAX_SESSION_EXPIRY_MINUTES=1440
CODE_LENGTH=6
