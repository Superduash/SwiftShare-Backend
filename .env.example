# Required
MONGODB_URI=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=swiftshare
FRONTEND_URL=https://your-frontend.vercel.app
SHARE_BASE_URL=https://your-frontend.vercel.app

# Optional (graceful if missing)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SENTRY_DSN=
# Optional CORS helpers
# CORS_EXTRA_ORIGINS supports comma-separated values and wildcard hosts like https://*.vercel.app
CORS_EXTRA_ORIGINS=
# Set to true only for temporary deployment diagnostics
CORS_ALLOW_ALL_ORIGINS=false

# Tuning
PORT=3001
NODE_ENV=production
LOG_LEVEL=warn
MAX_FILE_SIZE_MB=100
MAX_FILE_COUNT=5
SESSION_EXPIRY_MINUTES=10
HEALTH_CACHE_TTL_MS=15000
HEALTH_CHECK_TIMEOUT_MS=4000
QR_BRANDED=true
